# =============================================================================
# Ayantaraz .gitignore
# Comprehensive ignore patterns for Node.js, TypeScript, Docker, and IDE files
# =============================================================================

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.*
.pnpm-store/

# Yarn (if used)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Build Outputs
# =============================================================================
# API build
dist/
build/

# Web build (Next.js)
.next/
out/

# TypeScript
tsconfig.tsbuildinfo
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# =============================================================================
# Environment Files
# =============================================================================
# Local environment files
.env
.env.local
.env.*.local

# Production environment files (keep .env.example and .env.production)
.env.development
.env.staging
.env.test

# IDE-specific environment files
.vscode/.env
.idea/.env

# =============================================================================
# IDE Configuration
# =============================================================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ/WebStorm
.idea/
*.iml
*.ipr
*.iws

# Other IDEs
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# OS Files
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.temp
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# =============================================================================
# Logs
# =============================================================================
# Node.js logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docker logs
docker-logs/

# Application logs
logs/
*.log.*

# =============================================================================
# Docker
# =============================================================================
# Docker data volumes
docker-data/
pgdata/
redis-data/

# Docker compose override files (local)
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# Deploy Artifacts
# =============================================================================
.deploy_events.log
.deploy_receipt_*.json
.deploy_snapshot.json

# =============================================================================
# Platform-Specific
# =============================================================================
# Vercel
.vercel

# Netlify
.netlify/

# Heroku
.heroku/

# AWS
.elasticbeanstalk/

# =============================================================================
# Prisma
# =============================================================================
# Local migration files (keep schema migrations)
prisma/migrations/dev.db*
prisma/migrations/dev_migration_lock.toml

# Prisma binary cache
prisma/.prisma-client/

# =============================================================================
# Turbo/Build Cache
# =============================================================================
.turbo/

# =============================================================================
# Test Files
# =============================================================================
# Test results
test-results/
junit.xml

# Test coverage (already covered above)

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.temp

# =============================================================================
# Uploads (keep directory, ignore contents)
# =============================================================================
uploads/
!uploads/.gitkeep

# =============================================================================
# Backup Files
# =============================================================================
*.bak
*.backup
*.old
*.orig

# =============================================================================
# Editor Files
# =============================================================================
# Sublime Text
*.sublime-workspace
*.sublime-project

# Atom
*.atom/

# Emacs
*#
.

# =============================================================================
# Security
# =============================================================================
# Private keys and certificates
*.pem
*.key
*.crt
*.cert
*.pfx
*.p12

# =============================================================================
# Miscellaneous
# =============================================================================
# Cache directories
.cache/

# Local history
.history/

# Version control (other than git)
.svn/
.CVS/
.hg/

# =============================================================================
# Note: The following files are COMMITTED to the repository:
# =============================================================================
# - .env.example (template)
# - .env.production (production configuration with secure defaults)
# - docker-compose.yml (base configuration)
# - docker-compose.production.yml (production override)
# - docker-compose.prod.yml (alternative production configuration)
# - .github/workflows/*.yml (CI/CD workflows)
# - package.json, pnpm-lock.yaml (dependencies)
# - prisma/schema.prisma (database schema)
# - All source code in apps/, packages/, etc.
# =============================================================================
