{
  "schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "psr-engine-schema",
  "version": "1.0",
  "title": "Production Stability Review Engine — Agent Schema",
  "description": "Machine-readable schema for orchestrator-based production audit. Defines modules, checks, scoring, and output format.",
  "type": "object",

  "definitions": {
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Risk severity classification"
    },
    "status": {
      "type": "string",
      "enum": ["green", "yellow", "red"],
      "description": "Overall status of a domain or the entire review"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "0=missing, 1=weak, 2=partial, 3=acceptable, 4=good, 5=production-ready"
    },
    "finding": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^(C|H|M|L)-\\d{3}$" },
        "module": { "type": "string" },
        "category": { "type": "string" },
        "issue": { "type": "string" },
        "severity": { "$ref": "#/definitions/severity" },
        "location": { "type": "string", "description": "File path or endpoint" },
        "detail": { "type": "string" },
        "action": { "type": "string" },
        "isReleaseBlocker": { "type": "boolean" }
      },
      "required": ["id", "module", "issue", "severity", "action"]
    },
    "actionItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "issue": { "type": "string" },
        "fix": { "type": "string" },
        "owner": { "type": "string" },
        "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "eta": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "blocksRelease": { "type": "boolean" }
      },
      "required": ["id", "fix", "priority"]
    },
    "moduleChecklist": {
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "expected": { "type": "string" },
              "actual": { "type": "string" },
              "pass": { "type": "boolean" },
              "severity": { "$ref": "#/definitions/severity" }
            },
            "required": ["id", "description", "expected", "pass", "severity"]
          }
        },
        "score": { "$ref": "#/definitions/score" }
      },
      "required": ["module", "checks", "score"]
    },
    "domainScore": {
      "type": "object",
      "properties": {
        "domain": { "type": "string", "enum": ["security", "correctness", "stability", "observability", "maintainability", "freshness", "production_safety"] },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "score": { "$ref": "#/definitions/score" },
        "status": { "$ref": "#/definitions/status" }
      },
      "required": ["domain", "score"]
    }
  },

  "type": "object",
  "properties": {
    "engine": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "const": "PSR-Engine" },
        "version": { "type": "string", "const": "1.0" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "version", "timestamp"]
    },

    "config": {
      "type": "object",
      "properties": {
        "projectRoot": { "type": "string" },
        "modules": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["auth", "admin", "content", "consultation", "orders", "chatbot", "seo", "responsive", "security", "monitoring"]
          }
        },
        "analysisLayers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["static", "runtime", "domain", "freshness"]
          }
        },
        "releaseBlockerRules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "pattern": "^R\\d+$" },
              "condition": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["id", "condition"]
          }
        }
      },
      "required": ["projectRoot", "modules"]
    },

    "inventory": {
      "type": "object",
      "properties": {
        "modules": { "type": "array", "items": { "type": "string" } },
        "endpoints": { "type": "array", "items": { "type": "string" } },
        "models": { "type": "array", "items": { "type": "string" } },
        "configs": { "type": "array", "items": { "type": "string" } },
        "docs": { "type": "array", "items": { "type": "string" } },
        "scripts": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "array", "items": { "type": "string" } }
      }
    },

    "findings": {
      "type": "object",
      "properties": {
        "critical": { "type": "array", "items": { "$ref": "#/definitions/finding" } },
        "high": { "type": "array", "items": { "$ref": "#/definitions/finding" } },
        "medium": { "type": "array", "items": { "$ref": "#/definitions/finding" } },
        "low": { "type": "array", "items": { "$ref": "#/definitions/finding" } }
      }
    },

    "moduleResults": {
      "type": "object",
      "patternProperties": {
        "^(auth|admin|content|consultation|orders|chatbot|seo|responsive|security|monitoring)$": {
          "$ref": "#/definitions/moduleChecklist"
        }
      }
    },

    "scoring": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "$ref": "#/definitions/domainScore" }
        },
        "compositeScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "overallStatus": {
          "$ref": "#/definitions/status"
        }
      },
      "required": ["domains", "compositeScore", "overallStatus"]
    },

    "actionPlan": {
      "type": "array",
      "items": { "$ref": "#/definitions/actionItem" }
    },

    "recheckList": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "verified": { "type": "boolean" }
        },
        "required": ["id", "description"]
      }
    },

    "policyViolations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "$ref": "#/definitions/severity" }
        },
        "required": ["rule", "description", "severity"]
      }
    }
  },

  "required": ["engine", "config", "findings", "scoring", "actionPlan"]
}
