FROM node:22.16-alpine

RUN apk add --no-cache coreutils

ENV CI=true
ENV NODE_OPTIONS="--max-old-space-size=4096"

RUN npm install -g pnpm@11.9.0 --silent 2>/dev/null

WORKDIR /app

# Copy workspace files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY apps/web apps/web/
COPY packages/shared packages/shared/

# Build
RUN CI=true pnpm --filter=web build

# Find correct standalone structure and copy files
RUN if [ -d /app/apps/web/.next/standalone/apps/web ]; then \
      echo "Found nested standalone structure"; \
      mkdir -p /app/apps/web/.next/standalone/apps/web/.next/static; \
      cp -r /app/apps/web/.next/static/* /app/apps/web/.next/standalone/apps/web/.next/static/ 2>/dev/null || true; \
      cp -r /app/apps/web/public /app/apps/web/.next/standalone/apps/web/public 2>/dev/null || true; \
    else \
      echo "Found flat standalone structure"; \
      mkdir -p /app/apps/web/.next/standalone/.next/static; \
      cp -r /app/apps/web/.next/static/* /app/apps/web/.next/standalone/.next/static/ 2>/dev/null || true; \
      cp -r /app/apps/web/public /app/apps/web/.next/standalone/public 2>/dev/null || true; \
    fi

# Verify server.js exists
RUN find /app/apps/web/.next/standalone -name "server.js" -type f

ENV NODE_ENV=production

COPY infra/docker/entrypoint-web.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
