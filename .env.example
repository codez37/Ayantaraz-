# =============================================================================
# Ayantaraz Environment Configuration Example
# Server: 202.133.91.13
# DO NOT COMMIT THIS FILE WITH REAL VALUES
# Copy this to .env and fill in your own values
# Generate secure values: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
DOCKER_ENV=true
API_URL=http://202.133.91.13:3001
FRONTEND_URL=http://202.133.91.13:3000
SITE_URL=http://202.133.91.13

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# Generate secure passwords: openssl rand -base64 32
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/ayantaraz?schema=public
POSTGRES_USER=ayantaraz
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD_64_CHARS
POSTGRES_DB=ayantaraz

# -----------------------------------------------------------------------------
# Redis Configuration
# Generate secure password: openssl rand -base64 32
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD_64_CHARS
REDIS_URL=redis://:CHANGE_ME_GENERATE_SECURE_PASSWORD_64_CHARS@redis:6379

# -----------------------------------------------------------------------------
# JWT Authentication
# Generate 32+ character secrets: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_GENERATE_JWT_SECRET_32_PLUS_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_JWT_REFRESH_SECRET_32_PLUS_CHARS
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
FILE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_FILE_ENCRYPTION_KEY_32_PLUS_CHARS
CAPTCHA_SECRET=
ALLOW_ALL_ORIGINS=true
TRUSTED_ORIGINS=http://202.133.91.13,http://202.133.91.13:3000,http://202.133.91.13:3001

# -----------------------------------------------------------------------------
# Cookie Settings
# Set COOKIE_SECURE=true in production with HTTPS
# -----------------------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=202.133.91.13

# -----------------------------------------------------------------------------
# Database Connection Pool
# -----------------------------------------------------------------------------
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_MIN_CONNECTIONS=5
DB_POOL_MAX_REQUESTS_PER_CONNECTION=100
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_SECRET=CHANGE_ME_GENERATE_SESSION_SECRET_32_PLUS_CHARS

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# SMS Configuration
# -----------------------------------------------------------------------------
SMS_API_KEY=YOUR_SMS_PROVIDER_API_KEY
SMS_PROVIDER=sms-panel
SMS_FROM=Ayantaraz

# -----------------------------------------------------------------------------
# Admin Phone Numbers (Pre-seeded in database)
# -----------------------------------------------------------------------------
ADMIN_PHONE_1=09133374162
ADMIN_PHONE_2=09134292329

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/json

# -----------------------------------------------------------------------------
# Health Check Configuration
# -----------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30000