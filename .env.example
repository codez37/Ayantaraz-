TRUSTED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=localhost
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_MIN_CONNECTIONS=5
DB_POOL_MAX_REQUESTS_PER_CONNECTION=100
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
SESSION_SECRET=your_session_secret_32_chars
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SMS_API_KEY=your_sms_api_key
SMS_PROVIDER=sms-panel
SMS_FROM=Ayantaraz
ADMIN_PHONE_1=09133374162
ADMIN_PHONE_2=09134292329
