JWT_SECRET=your_jwt_secret_key_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_32_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
FILE_ENCRYPTION_KEY=your_32_char_encryption_key
CAPTCHA_SECRET=
